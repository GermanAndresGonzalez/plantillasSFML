<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="PlantillaSFML" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Option virtualFolders="Menu/;Ventana/;ArchivosDatos/" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/PlantillaSFML" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/PlantillaSFML" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add directory="SFML/include" />
		</Compiler>
		<Linker>
			<Add library="sfml-audio" />
			<Add library="sfml-graphics" />
			<Add library="sfml-window" />
			<Add library="sfml-system" />
			<Add directory="SFML/lib" />
		</Linker>
		<Unit filename="VentanaExplorar.cpp">
			<Option virtualFolder="Ventana/" />
		</Unit>
		<Unit filename="VentanaExplorar.h">
			<Option virtualFolder="Ventana/" />
		</Unit>
		<Unit filename="botonera.cpp">
			<Option virtualFolder="Menu/" />
		</Unit>
		<Unit filename="botonera.h">
			<Option virtualFolder="Menu/" />
		</Unit>
		<Unit filename="datosBotonera.cpp">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="datosBotonera.h">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="datosVentExplorar.cpp">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="datosVentExplorar.h">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="datosVentana.cpp">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="datosVentana.h">
			<Option virtualFolder="ArchivosDatos/" />
		</Unit>
		<Unit filename="main.cpp" />
		<Unit filename="ventana.cpp">
			<Option virtualFolder="Ventana/" />
		</Unit>
		<Unit filename="ventana.h">
			<Option virtualFolder="Ventana/" />
		</Unit>
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
